#!/bin/bash

START_TIME=`date +%s`
GCP_THREAD=gcp-thread-$START_TIME
NODE_THREAD=node-thread-$START_TIME

# Assign parameters to readable names
FULL_COMMIT_HASH=$1
BRANCH_NAME=$2
BUILD_NUM=$3
BUILD_CAUSE=$4

if [[ "$BUILD_CAUSE" == *Timer* ]]; then
        export BUILD_USER="jenkins-bot"
    else
    # "Set Jenkins user build variables" plugin sets BUILD_USER_ID
        export BUILD_USER="${BUILD_CAUSE}"
    fi

TARGET_DIR="/home/praveen/deployed_app"

echo "📝 Generating deployment parameters..."

# Create the folder if it doesn't exist
mkdir -p "$TARGET_DIR"

# Write to param.txt
{
    echo "DEPLOYMENT_REPORT"
    echo "-----------------"
    echo "Build_Number: $BUILD_NUM"
    echo "Branch:       $BRANCH_NAME"
    echo "Commit:       $FULL_COMMIT_HASH"
    echo "Cause:        $BUILD_CAUSE"
    echo "Date:         $(date)"
    echo "User:		$BUILD_USER"
} > "$TARGET_DIR/param.txt"

# --- Proceed to Java Build ---
echo "🛠 Building Java Artifact..."
