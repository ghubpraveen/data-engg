pipeline {
    agent any
    environment {
        SCRIPT_PATH = "/home/praveen/app_scripts/java_deployment.sh"
    }
    stages {
        stage('Collect Data & Deploy') {
            steps {
                script {
                    // 1. Gather Variables
                    def commit = sh(script: "git rev-parse --short HEAD", returnStdout: true).trim()
                    def branch = sh(script: "git rev-parse --abbrev-ref HEAD", returnStdout: true).trim()
                    def buildNum = env.BUILD_NUMBER
                    def cause = currentBuild.getBuildCauses()[0].shortDescription
                    
                    // 2. Pass them to the script as arguments
                    // Order: $1=hash, $2=branch, $3=buildNum, $4=cause
                    sh "bash ${env.SCRIPT_PATH} '${commit}' '${branch}' '${buildNum}' '${cause}'"
                }
            }
        }
    }
}


#!/bin/bash

# Assign parameters to readable names
COMMIT_HASH=$1
BRANCH_NAME=$2
BUILD_NUM=$3
BUILD_CAUSE=$4
TARGET_DIR="/home/praveen/deployed_app"

echo "📝 Generating deployment parameters..."

# Create the folder if it doesn't exist
mkdir -p "$TARGET_DIR"

# Write to param.txt
{
    echo "DEPLOYMENT_REPORT"
    echo "-----------------"
    echo "Build_Number: $BUILD_NUM"
    echo "Branch:       $BRANCH_NAME"
    echo "Commit:       $COMMIT_HASH"
    echo "Cause:        $BUILD_CAUSE"
    echo "Date:         $(date)"
} > "$TARGET_DIR/param.txt"

# --- Proceed to Java Build ---
