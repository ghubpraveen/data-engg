# 🧾 8️⃣ GitHub Actions Workflow

```yaml
name: Full Deployment Pipeline

on:
  push:
    branches:
      - uat

jobs:
  deploy:
    runs-on: self-hosted

    steps:
      - name: Checkout
        uses: actions/checkout@v4

      - name: Debug Runner
        run: |
          echo "User: $(whoami)"
          echo "Host: $(hostname)"
          pwd

      - name: Run Deployment Script
        env:
          JOB_NAME: "UAT_Deployment"
          BRANCH: "uat"
          BUILD_ENV: "uat"
          REQUIRED: "Build"
          REPO_WORKSPACE: ${{ github.workspace }}
          TOMCAT_BRANCH: "uat"
          BUILD_USER: ${{ github.actor }}
          VALIDATE_HASHES: "yes"

          GCHAT_URL: ${{ secrets.GCHAT_URL }}
          DEV_GCHAT_URL: ${{ secrets.DEV_GCHAT_URL }}

          AWS_ACCESS_KEY_ID: ${{ secrets.AWS_ACCESS_KEY_ID }}
          AWS_SECRET_ACCESS_KEY: ${{ secrets.AWS_SECRET_ACCESS_KEY }}

          ELASTIC_USER: ${{ secrets.ELASTIC_USER }}
          ELASTIC_PASS: ${{ secrets.ELASTIC_PASS }}

        run: |
          chmod +x scripts/java_deployment.sh
          scripts/java_deployment.sh \
            "$JOB_NAME" \
            "$BRANCH" \
            "$BUILD_ENV" \
            "$REQUIRED" \
            "$REPO_WORKSPACE" \
            "$TOMCAT_BRANCH" \
            "$BUILD_USER" \
            "$VALIDATE_HASHES"
```

