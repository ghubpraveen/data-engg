#!/bin/bash
set -e
trap 'echo "❌ Failed at line $LINENO"' ERR

# ── GChat Webhook URL ─────────────────────────────────────
# Replace this with your team's GChat webhook URL
GCHAT_URL="REPLACE_WITH_YOUR_GCHAT_WEBHOOK_URL"

# ── GChat Alert Function ──────────────────────────────────
send_gchat() {
    local MESSAGE=$1
    curl -sH 'Content-Type: application/json' \
        -X POST "$GCHAT_URL" \
        --data "{\"text\": \"$MESSAGE\"}" >> /dev/null
}

# ── Step 1: Read the params file ──────────────────────────
PARAMS_FILE=$1

if [[ -z "$PARAMS_FILE" || ! -f "$PARAMS_FILE" ]]; then
    echo "❌ ERROR: Params file not found: $PARAMS_FILE"
    send_gchat "❌ *$JOB_NAME* — Params file not found. Build aborted."
    exit 1
fi

echo "📄 Reading params from: $PARAMS_FILE"
set -a
source "$PARAMS_FILE"
set +a

# ── Step 2: Print what we got ─────────────────────────────
echo "==============================="
echo "JOB_NAME    : $JOB_NAME"
echo "BRANCH      : $BRANCH"
echo "COMMIT_HASH : $COMMIT_HASH"
echo "BUILD_ENV   : $BUILD_ENV"
echo "REQUIRED    : $REQUIRED"
echo "WORKSPACE   : $WORKSPACE"
echo "==============================="

# Notify GChat that build has started
send_gchat "🔨 *$JOB_NAME* — Build started on branch *$BRANCH* by $BUILD_CAUSE \nCommit: \`${COMMIT_HASH:0:7}\`"

# ── Step 3: Build WAR ─────────────────────────────────────
cd "$WORKSPACE"

echo "🔨 Starting Maven WAR build..."
mvn clean package -DskipTests

# ── Step 4: Confirm WAR was created ───────────────────────
WAR_FILE="$WORKSPACE/target/SampleWebApp.war"

if [[ -f "$WAR_FILE" ]]; then
    echo "✅ WAR built successfully: $WAR_FILE"
    ls -lh "$WAR_FILE"
    send_gchat "✅ *$JOB_NAME* — WAR built successfully on branch *$BRANCH* \nCommit: \`${COMMIT_HASH:0:7}\`"
else
    echo "❌ WAR file not found after build!"
    send_gchat "❌ *$JOB_NAME* — WAR build failed on branch *$BRANCH* \nCommit: \`${COMMIT_HASH:0:7}\`"
    exit 1
fi
