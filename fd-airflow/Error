# --- Improved Logic Block ---
if [[ "$BUILD_CAUSE" == *Timer* ]]; then
    export BUILD_USER="jenkins-bot"
elif [[ "$BUILD_CAUSE" == *SCM* ]]; then
    export BUILD_USER="github-webhook"
elif [[ "$BUILD_CAUSE" == *user* ]]; then
    # Extracts name from "Started by user Praveen"
    export BUILD_USER=$(echo "$BUILD_CAUSE" | sed 's/Started by user //')
else
    export BUILD_USER="system-id"
fi
